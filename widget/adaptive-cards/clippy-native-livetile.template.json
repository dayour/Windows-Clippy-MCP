{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "fallbackText": "Windows Clippy native live tile for ${title}",
  "body": [
    {
      "type": "TextBlock",
      "text": "${title}",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "${summary}",
      "spacing": "None",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Agent",
          "value": "${generation.agent}"
        },
        {
          "title": "Tool",
          "value": "${generation.tool}"
        },
        {
          "title": "Bridge",
          "value": "${generation.bridge}"
        },
        {
          "title": "State",
          "value": "${iconAssets.selectedState}"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Capabilities",
          "weight": "Bolder",
          "wrap": true
        },
        {
          "type": "Container",
          "$data": "${capabilities}",
          "items": [
            {
              "type": "TextBlock",
              "text": "- ${$data}",
              "wrap": true,
              "spacing": "Small"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "$when": "${tools}",
      "items": [
        {
          "type": "TextBlock",
          "text": "Connected tools",
          "weight": "Bolder",
          "wrap": true
        },
        {
          "type": "Container",
          "$data": "${tools}",
          "items": [
            {
              "type": "TextBlock",
              "text": "${name} [${kind}]",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "${purpose}",
              "wrap": true,
              "size": "Small",
              "isSubtle": true,
              "spacing": "None"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Review",
          "weight": "Bolder",
          "wrap": true
        },
        {
          "type": "TextBlock",
          "text": "${review.summary}",
          "wrap": true,
          "size": "Small"
        }
      ]
    }
  ]
}
