<Window x:Class="TerminalHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ewt="clr-namespace:EasyWindowsTerminalControl;assembly=EasyWindowsTerminalControl"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Clippy Terminal Host"
        Width="960"
        Height="640"
        MinWidth="320"
        MinHeight="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#1A1A2B">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="#1A1A2B"
            SnapsToDevicePixels="True">
        <ewt:EasyTerminalControl x:Name="Terminal"
                                 Background="#1A1A2B"
                                 FontFamilyWhenSettingTheme="Cascadia Code"
                                 FontSizeWhenSettingTheme="14"
                                 LogConPTYOutput="False"
                                 Win32InputMode="True"
                                 InputCapture="TabKey,DirectionKeys" />
    </Border>
</Window>
