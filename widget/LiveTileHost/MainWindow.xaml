<Window x:Class="LiveTileHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Clippy Live Tile"
        Width="432"
        Height="720"
        MinWidth="360"
        MinHeight="520"
        Background="#08111F"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="#FFF4F7FF" />
            <Setter Property="Background" Value="#1D2D50" />
            <Setter Property="BorderBrush" Value="#365CBA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#27447A" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#4F7AF2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#162540" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FactItemTemplate">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}"
                           Foreground="#FF9AB7FF"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Value}"
                           Foreground="#FFF4F7FF"
                           TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ToolItemTemplate">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    CornerRadius="12"
                    Background="#141F37"
                    BorderBrush="#233A6D"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Purpose}"
                               Margin="0,6,0,0"
                               Foreground="#FFD5E0FF"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Source}"
                               Margin="0,6,0,0"
                               Foreground="#FF8AA5E8"
                               FontFamily="Cascadia Mono"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TextItemTemplate">
            <Border Margin="0,0,0,8"
                    Padding="10"
                    CornerRadius="10"
                    Background="#121A2C"
                    BorderBrush="#213253"
                    BorderThickness="1">
                <TextBlock Text="{Binding}"
                           Foreground="#FFE5ECFF"
                           TextWrapping="Wrap" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="ChromeBorder"
            Margin="10"
            Padding="0"
            CornerRadius="18"
            Background="#0F182A"
            BorderBrush="#365CBA"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBorder"
                    Background="#12203A"
                    CornerRadius="18,18,0,0"
                    Padding="16,14,16,14"
                    MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="WindowTitleText"
                                   Text="Windows Clippy Live Tile"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,4,0,0"
                                   Foreground="#FFB6C9FF"
                                   FontSize="11.5"
                                   Text="Waiting for payload." />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource ChromeButtonStyle}"
                                Click="OnRefreshClick"
                                Content="Refresh" />
                        <Button x:Name="PinButton"
                                Style="{StaticResource ChromeButtonStyle}"
                                Click="OnPinClick"
                                Content="Pinned" />
                        <Button Style="{StaticResource ChromeButtonStyle}"
                                Click="OnCloseClick"
                                Content="Close" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="16,14,16,0"
                    Padding="16"
                    Background="#101C33"
                    BorderBrush="#223A73"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="132"
                            Height="132"
                            CornerRadius="22"
                            Background="#15284B"
                            BorderBrush="#4E77F4"
                            BorderThickness="1">
                        <Image x:Name="HeroImage"
                               Margin="10"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="TileTitleText"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="TileSummaryText"
                                   Margin="0,8,0,0"
                                   Foreground="#FFDDE7FF"
                                   TextWrapping="Wrap" />
                        <WrapPanel Margin="0,12,0,0">
                            <StackPanel Margin="0,0,18,0">
                                <TextBlock Text="Default 32"
                                           Foreground="#FF8DA7E2"
                                           FontSize="11" />
                                <Border Width="44"
                                        Height="44"
                                        Margin="0,6,0,0"
                                        Padding="6"
                                        Background="#0C1424"
                                        BorderBrush="#294B97"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Image x:Name="Default32Image"
                                           Stretch="Uniform" />
                                </Border>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Focused 32"
                                           Foreground="#FF8DA7E2"
                                           FontSize="11" />
                                <Border Width="44"
                                        Height="44"
                                        Margin="0,6,0,0"
                                        Padding="6"
                                        Background="#0C1424"
                                        BorderBrush="#294B97"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Image x:Name="Focused32Image"
                                           Stretch="Uniform" />
                                </Border>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="ContentScrollViewer"
                          Grid.Row="2"
                          Margin="16,14,16,14"
                          VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False"
                          PanningMode="VerticalOnly"
                          PreviewMouseWheel="OnContentScrollViewerPreviewMouseWheel"
                          ScrollChanged="OnContentScrollViewerScrollChanged">
                <StackPanel>
                    <TextBlock Text="Live tile capabilities"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <ItemsControl x:Name="CapabilitiesItems"
                                  Margin="0,10,0,0"
                                  ItemTemplate="{StaticResource TextItemTemplate}" />

                    <TextBlock Margin="0,16,0,0"
                               Text="Generation"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <ItemsControl x:Name="GenerationFactsItems"
                                  Margin="0,10,0,0"
                                  ItemTemplate="{StaticResource FactItemTemplate}" />

                    <TextBlock Margin="0,16,0,0"
                               Text="Connected tools"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <ItemsControl x:Name="ToolsItems"
                                  Margin="0,10,0,0"
                                  ItemTemplate="{StaticResource ToolItemTemplate}" />

                    <TextBlock Margin="0,16,0,0"
                               Text="Review"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ReviewSummaryText"
                               Margin="0,10,0,0"
                               Foreground="#FFF4F7FF"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="ReviewNotesItems"
                                  Margin="0,10,0,0"
                                  ItemTemplate="{StaticResource TextItemTemplate}" />

                    <TextBlock Margin="0,16,0,0"
                               Text="Artifact paths"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <ItemsControl x:Name="ArtifactItems"
                                  Margin="0,10,0,0"
                                  ItemTemplate="{StaticResource FactItemTemplate}" />
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Background="#0B1221"
                    CornerRadius="0,0,18,18"
                    BorderBrush="#1E335D"
                    BorderThickness="1,1,0,0"
                    Padding="16,12,16,14">
                <StackPanel>
                    <TextBlock x:Name="AdaptiveVersionText"
                               Foreground="#FF9BB4F2"
                               FontSize="11.5"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DataPathText"
                               Margin="0,6,0,0"
                               Foreground="#FFDCE5FF"
                               FontFamily="Cascadia Mono"
                               FontSize="10.5"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TemplatePathText"
                               Margin="0,4,0,0"
                               Foreground="#FFA8BDEB"
                               FontFamily="Cascadia Mono"
                               FontSize="10.5"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="SchemaPathText"
                               Margin="0,4,0,0"
                               Foreground="#FFA8BDEB"
                               FontFamily="Cascadia Mono"
                               FontSize="10.5"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
