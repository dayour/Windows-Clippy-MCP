<Window x:Class="WidgetHost.CommanderCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clippy Commander"
        Width="540"
        Height="620"
        MinWidth="420"
        MinHeight="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border Background="#F20E0E1F"
            BorderBrush="#663A3A66"
            BorderThickness="1"
            CornerRadius="16"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              BlurRadius="26"
                              ShadowDepth="8"
                              Opacity="0.55" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FF181832"
                    BorderBrush="#FF2A2A44"
                    BorderThickness="0,0,0,1"
                    CornerRadius="15,15,0,0"
                    Padding="14,0">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Clippy Commander"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="13"
                                   Foreground="#FFE8E8E8"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText"
                                   Text=" - background command card"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FF8F8FAF"
                                   VerticalAlignment="Center"
                                   Margin="6,1,0,0" />
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Text="LAYER 2"
                               FontFamily="Segoe UI Semibold"
                               FontSize="10"
                               Foreground="#FF8B8BF0"
                               Opacity="0.8" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    x:Name="HostSlot"
                    Background="#FF0E0E1F"
                    BorderBrush="#FF2A2A44"
                    BorderThickness="0"
                    CornerRadius="0,0,15,15" />
        </Grid>
    </Border>
</Window>
