<Window x:Class="WidgetHost.FleetStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clippy Fleet Status"
        Width="720"
        Height="900"
        MinWidth="480"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF0E0E1F"
        Foreground="#FFE8E8E8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FF161634"
                BorderBrush="#FF2A2A44"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Clippy Fleet Status"
                           FontFamily="Segoe UI Semibold"
                           FontSize="14"
                           Foreground="#FFE8E8E8"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderSubtitle"
                           Text=" - live MCP App view"
                           Foreground="#FF8F8FAF"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                x:Name="HostSlot"
                Background="#FF0E0E1F"
                BorderBrush="#FF2A2A44"
                BorderThickness="0"
                Margin="0" />

        <Border Grid.Row="2"
                Background="#FF111122"
                BorderBrush="#FF2A2A44"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Loading..."
                           Foreground="#FF8F8FAF"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        x:Name="CloseBtn"
                        Content="Close"
                        Width="80"
                        Height="28"
                        Background="#FF5B5FC7"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="OnCloseClick">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
